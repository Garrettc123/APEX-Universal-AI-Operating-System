# ── Application ──────────────────────────────────────────
# Server configuration
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=info

# CORS - comma-separated list of allowed origins (leave empty to allow all in dev)
ALLOWED_ORIGINS=https://your-domain.com,https://api.your-domain.com

# Optional: persist revenue-engine state across restarts (JSON file fallback)
APEX_STATE_FILE=

# Database (Supabase / Postgres) — when set, used for revenue state and
# Stripe-driven entitlements (see src/db.py + supabase/migrations). Requires
# `pip install "psycopg[binary]"`. Leave empty to use the JSON/in-memory fallback.
# Local Supabase default: postgresql://postgres:postgres@localhost:54322/postgres
DATABASE_URL=
SUPABASE_DB_URL=

# Where contact-sales / enterprise inquiries are routed (shown in /pricing)
CONTACT_SALES_EMAIL=gwc2780@gmail.com

# ── Billing (Stripe) ──────────────────────────────────────
# Self-serve checkout (POST /api/checkout) is DISABLED until STRIPE_SECRET_KEY
# is set. Use sk_test_... for testing, sk_live_... for production.
STRIPE_SECRET_KEY=
# Stripe Price IDs per plan (create them in the Stripe dashboard)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=
# Webhook signing secret (whsec_...) — enables POST /api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=
# Post-checkout redirect URLs
CHECKOUT_SUCCESS_URL=https://your-domain.com/success
CHECKOUT_CANCEL_URL=https://your-domain.com/cancel

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_DB=db
POSTGRES_USER=user
POSTGRES_PASSWORD=change_me_strong_password_here
DATABASE_URL=postgresql://user:change_me_strong_password_here@localhost/db

# ── MongoDB ───────────────────────────────────────────────
MONGO_USER=admin
MONGO_PASSWORD=change_me_strong_password_here
MONGODB_URI=mongodb://admin:change_me_strong_password_here@localhost:27017

# ── Redis ─────────────────────────────────────────────────
REDIS_PASSWORD=change_me_strong_password_here
REDIS_URL=redis://:change_me_strong_password_here@localhost:6379
